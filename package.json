{
  "name": "stats-store",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-focused analytics dashboard for Sparkle-enabled macOS applications",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "pnpm format:check && oxlint -c .oxlintrc.json --deny-warnings --import-plugin --react-plugin --nextjs-plugin --vitest-plugin --type-aware --tsconfig tsconfig.oxlint.json app components hooks lib tests",
    "lint:fix": "pnpm format && oxlint -c .oxlintrc.json --deny-warnings --import-plugin --react-plugin --nextjs-plugin --vitest-plugin --type-aware --tsconfig tsconfig.oxlint.json --fix app components hooks lib tests",
    "start": "next start",
    "test": "cross-env NODE_NO_WARNINGS=1 vitest run",
    "test:api": "cross-env NODE_NO_WARNINGS=1 vitest run --dir tests/api",
    "test:components": "cross-env NODE_NO_WARNINGS=1 vitest run --dir tests/components",
    "test:coverage": "cross-env NODE_NO_WARNINGS=1 vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@edge-runtime/vm": "latest",
