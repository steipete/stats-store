    "@vitest/ui": "^4.1.5",
    "cross-env": "^10.1.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.33.2"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
